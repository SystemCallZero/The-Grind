*.creator.user.*
*.pro.user
*.pro.user.*
*.includes
*.config
*.creator

# Makefile (генерируется qmake)
Makefile
Makefile.*
*.make
*.qmake.stash

# Папки с объектными файлами (Debug/Release)
debug/
release/
debug_*
release_*
*.debug
*.release

